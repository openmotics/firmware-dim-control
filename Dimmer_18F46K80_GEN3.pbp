PCF8574A_ADDRESS        con     %01110000
M24C02_ADDRESS          CON     %10101100

MAXRS485LENGTH          con     11  'Max length (in RS485 message) that can be used. Cannot be increased without changing variables A_Queue_...

LED_ON                  con     1
LED_OFF                 con     0
YES                     con     1
NO                      con     0

'hier core
CORE                    con     0
