PCF8574i2ccont          var     byte
PCF8574i2ccont=PCF8574_ADDRESS

i2ccont                 var     byte     'chip address
i2cdata                 var     byte[MAXI2CBYTES]     'data to read or write
i2cdataTemp             var     byte
